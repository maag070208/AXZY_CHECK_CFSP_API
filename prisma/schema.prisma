generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  value String
  users User[]
}

model Client {
  id           Int        @id @default(autoincrement())
  name         String     @unique
  address      String?
  rfc          String?
  contactName  String?
  contactPhone String?
  active       Boolean    @default(true)
  softDelete   Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  locations    Location[]
  rounds       Round[]
  users        User[]
  zones        Zone[]
  recurringConfigurations RecurringConfiguration[]
}

model Zone {
  id         Int        @id @default(autoincrement())
  clientId   Int
  name       String
  active     Boolean    @default(true)
  softDelete Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  client     Client     @relation(fields: [clientId], references: [id])
  locations  Location[]

  @@unique([name, clientId])
}

model User {
  id                       Int                      @id @default(autoincrement())
  name                     String
  lastName                 String?
  username                 String                   @unique
  password                 String
  active                   Boolean                  @default(true)
  softDelete               Boolean                  @default(false)
  shiftStart               String?
  shiftEnd                 String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  isLoggedIn               Boolean                  @default(false)
  scheduleId               Int?
  clientId                 Int?
  roleId                   Int
  assignments              Assignment[]             @relation("GuardAssignments")
  incidents                Incident[]
  resolvedIncidents        Incident[]               @relation("IncidentResolver")
  kardexEntries            Kardex[]
  maintenances             Maintenance[]
  resolvedMaintenances     Maintenance[]            @relation("MaintenanceResolver")
  rounds                   Round[]                  @relation("GuardRounds")
  client                   Client?                  @relation(fields: [clientId], references: [id])
  role                     Role                     @relation(fields: [roleId], references: [id])
  schedule                 Schedule?                @relation(fields: [scheduleId], references: [id])
  recurringConfigurations RecurringConfiguration[]
}

model Schedule {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  startTime String
  endTime   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Location {
  id                 Int                 @id @default(autoincrement())
  clientId           Int?
  zoneId             Int?
  aisle              String?
  spot               String?
  number             String?
  name               String
  reference          String?
  isOccupied         Boolean             @default(false)
  active             Boolean             @default(true)
  softDelete         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  client             Client?             @relation(fields: [clientId], references: [id])
  zone               Zone?               @relation(fields: [zoneId], references: [id])
  tasks              LocationTask[]
  assignments        Assignment[]
  kardexEntries      Kardex[]
  recurringLocations RecurringLocation[]

  @@unique([name, zoneId])
}

model LocationTask {
  id          Int      @id @default(autoincrement())
  locationId  Int
  description String
  reqPhoto    Boolean  @default(false)
  location    Location @relation(fields: [locationId], references: [id])
}

model Kardex {
  id           Int         @id @default(autoincrement())
  userId       Int
  locationId   Int
  timestamp    DateTime    @default(now())
  notes        String?
  media        Json?
  latitude     Float?
  longitude    Float?
  assignmentId Int?
  scanType     ScanType    @default(FREE)
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  location     Location    @relation(fields: [locationId], references: [id])
  user         User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([locationId])
  @@index([timestamp])
}

model Assignment {
  id         Int              @id @default(autoincrement())
  guardId    Int
  locationId Int
  status     AssignmentStatus @default(PENDING)
  assignedBy Int
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  guard      User             @relation("GuardAssignments", fields: [guardId], references: [id])
  location   Location         @relation(fields: [locationId], references: [id])
  tasks      AssignmentTask[]
  kardex     Kardex[]

  @@index([guardId])
  @@index([locationId])
}

model AssignmentTask {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  description  String
  reqPhoto     Boolean    @default(false)
  completed    Boolean    @default(false)
  completedAt  DateTime?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  @@index([assignmentId])
}

model IncidentCategory {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  value        String
  type         String         @default("INCIDENT") // INCIDENT or MAINTENANCE
  color        String?
  icon         String?
  types        IncidentType[]
  incidents    Incident[]
  maintenances Maintenance[]
}

model IncidentType {
  id           Int              @id @default(autoincrement())
  categoryId   Int
  name         String           @unique
  value        String
  category     IncidentCategory @relation(fields: [categoryId], references: [id])
  incidents    Incident[]
  maintenances Maintenance[]
}

model Incident {
  id           Int               @id @default(autoincrement())
  guardId      Int
  title        String
  categoryId   Int?
  typeId       Int?
  description  String?
  media        Json?
  latitude     Float?
  longitude    Float?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  resolvedAt   DateTime?
  resolvedById Int?
  status       IncidentStatus    @default(PENDING)
  category     IncidentCategory? @relation(fields: [categoryId], references: [id])
  type         IncidentType?     @relation(fields: [typeId], references: [id])
  guard        User              @relation(fields: [guardId], references: [id])
  resolvedBy   User?             @relation("IncidentResolver", fields: [resolvedById], references: [id])
}

model Round {
  id                       Int                     @id @default(autoincrement())
  guardId                  Int
  clientId                 Int?
  startTime                DateTime                @default(now())
  endTime                  DateTime?
  status                   RoundStatus             @default(IN_PROGRESS)
  recurringConfigurationId Int?
  guard                    User                    @relation("GuardRounds", fields: [guardId], references: [id])
  client                   Client?                 @relation(fields: [clientId], references: [id])
  recurringConfiguration   RecurringConfiguration? @relation(fields: [recurringConfigurationId], references: [id])
}

model SysConfig {
  key   String @id
  value String
}

model RecurringConfiguration {
  id        Int      @id @default(autoincrement())
  title     String
  clientId  Int?
  active    Boolean  @default(true)
  softDelete Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  client             Client?             @relation(fields: [clientId], references: [id])
  recurringLocations RecurringLocation[]
  guards             User[]
  rounds             Round[]
}

model RecurringLocation {
  id                       Int                    @id @default(autoincrement())
  recurringConfigurationId Int
  locationId               Int
  order                    Int                    @default(0)
  recurringConfiguration   RecurringConfiguration @relation(fields: [recurringConfigurationId], references: [id])
  location                 Location               @relation(fields: [locationId], references: [id])
  tasks                    RecurringTask[]
}

model RecurringTask {
  id                  Int               @id @default(autoincrement())
  recurringLocationId Int
  description         String
  reqPhoto            Boolean           @default(false)
  recurringLocation   RecurringLocation @relation(fields: [recurringLocationId], references: [id])
}

model Maintenance {
  id           Int               @id @default(autoincrement())
  guardId      Int
  title        String
  categoryId   Int?
  typeId       Int?
  category     String?
  description  String?
  media        Json?
  latitude     Float?
  longitude    Float?
  status       MaintenanceStatus @default(PENDING)
  resolvedAt   DateTime?
  resolvedById Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  guard        User              @relation(fields: [guardId], references: [id])
  resolvedBy   User?             @relation("MaintenanceResolver", fields: [resolvedById], references: [id])
  categoryRel  IncidentCategory? @relation(fields: [categoryId], references: [id])
  type         IncidentType?     @relation(fields: [typeId], references: [id])
}

enum AssignmentStatus {
  PENDING
  CHECKING
  UNDER_REVIEW
  REVIEWED
  ANOMALY
}

enum ScanType {
  ASSIGNMENT
  RECURRING
  FREE
}

enum IncidentStatus {
  PENDING
  ATTENDED
}

enum RoundStatus {
  IN_PROGRESS
  COMPLETED
}

enum MaintenanceStatus {
  PENDING
  ATTENDED
}
